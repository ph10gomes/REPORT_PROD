PORT=3001

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=senha_aqui
MYSQL_DATABASE=seu_banco

# Nome da tabela já existente que você quer ler
MYSQL_TABLE=report_csc_hoje
MYSQL_TABLE_CONTROLE_SERVICO=controle_servico
MYSQL_TABLE_HIST_ACORDOS=historico_acordos
MYSQL_TABLE_HIST_JUSTIFICATIVAS=historico_justificativas

# Opcional: se true/1, só traz linhas com `hora_atualizacao` exatamente em 9,11,13,15,17
MYSQL_STRICT_HOURS=false

# Opcional: se true/1, só conta equipes com INICIO_JORNADA preenchido (ou hora_ini_jornada não nulo)
MYSQL_ONLY_STARTED_JOURNEY=false
